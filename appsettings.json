{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      },
      "EnableDependencyTrackingTelemetryModule": false,
      "EnablePerformanceCounterCollectionModule": false
    }
  },
  "AzureStorageBlobs": {
    "Endpoint": "{{AZURE_STORAGE_BLOBS_ENDPOINT}}",
    "ContainerName": "{{AZURE_STORAGE_BLOBS_CONTAINER_NAME}}",
    "ClientId": "{{AZURE_STORAGE_BLOBS_CLIENT_ID}}"
  },
  "SwitchBot": {
    "Endpoint": "https://api.switch-bot.com/",
    "AccessToken": "{{SWITCHBOT_ACCESS_TOKEN}}",
    "ClientSecret": "{{SWITCHBOT_CLIENT_SECRET}}"
  }
}
